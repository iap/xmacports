#!/bin/bash
# System information

set -eu

echo "Development Environment System Information"
echo "Date: $(date)"
echo "OS: $(uname -sr)"
echo "Uptime: $(uptime 2> /dev/null || echo 'unavailable')"
echo "Shell: $SHELL"
echo "PATH: $PATH"
echo "XDG_CONFIG_HOME: ${XDG_CONFIG_HOME:-unset}"
echo "XDG_CACHE_HOME: ${XDG_CACHE_HOME:-unset}"
echo "XDG_STATE_HOME: ${XDG_STATE_HOME:-unset}"
echo "Terminal: $TERM"
echo "GPG Agent: $(pgrep gpg-agent > /dev/null 2>&1 && echo 'Running' || echo 'Not running')"
