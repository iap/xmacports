#!/bin/sh
# Pinentry fallback script

# MacPorts pinentry paths (not in default PATH)
PINENTRY_PATHS="/opt/local/bin /usr/local/bin /usr/bin"

# MacPorts app bundle path for pinentry-mac (discover version dynamically)
_find_pinentry_mac_bundle() {
  find /opt/local/var/macports/software/pinentry-mac -path '*/Applications/MacPorts/pinentry-mac.app/Contents/MacOS/pinentry-mac' -type f 2>/dev/null | head -1
}

PINENTRY_MAC_BUNDLE=$(_find_pinentry_mac_bundle)

# Try pinentry-mac first (GUI) - check both PATH and app bundle
if [ -n "$PINENTRY_MAC_BUNDLE" ] && [ -x "$PINENTRY_MAC_BUNDLE" ]; then
  exec "$PINENTRY_MAC_BUNDLE" "$@"
fi
for p in $PINENTRY_PATHS; do
  if [ -x "$p/pinentry-mac" ]; then
    exec "$p/pinentry-mac" "$@"
  fi
done

if [ -t 0 ]; then
  # Prefer pinentry-tty for terminal (simpler than curses, fewer glitches)
  for p in $PINENTRY_PATHS; do
    if [ -x "$p/pinentry-tty" ]; then
      exec "$p/pinentry-tty" "$@"
    fi
  done

  # Fallback to curses if tty not available
  for p in $PINENTRY_PATHS; do
    if [ -x "$p/pinentry-curses" ]; then
      exec "$p/pinentry-curses" "$@"
    fi
  done
fi

# Fallback: try any pinentry on PATH
if command -v pinentry > /dev/null 2>&1; then
  exec pinentry "$@"
fi

# Error handling
echo "ERROR: No pinentry program available." >&2
echo "Install a pinentry program and make it available on PATH." >&2
exit 1
