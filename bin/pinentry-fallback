#!/bin/sh
# Pinentry fallback script

# Try GUI pinentry if available
if command -v pinentry-mac >/dev/null 2>&1; then
  exec pinentry-mac "$@"
fi

if [ -t 0 ]; then
  # Prefer a terminal pinentry when running in a TTY.
  if command -v pinentry-curses >/dev/null 2>&1; then
    exec pinentry-curses "$@"
  fi

  if command -v pinentry-tty >/dev/null 2>&1; then
    exec pinentry-tty "$@"
  fi
fi

if command -v pinentry >/dev/null 2>&1; then
  exec pinentry "$@"
fi

# Error handling
echo "ERROR: No pinentry program available." >&2
echo "Install a pinentry program and make it available on PATH." >&2
exit 1
