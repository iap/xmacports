# Simple gitignore for dotfiles
# Protect sensitive information - never commit personal data
*.local
*.private
*_local
*_private

# System files
.DS_Store
*.log
*.tmp

# Sensitive data patterns
*password*
*secret*
*token*
*credential*
*.key
id_rsa
id_dsa
id_ecdsa
id_ed25519
id_ed25519_sk
*_key
*_rsa
*_dsa
*_ecdsa
*_ed25519
*.pem
*.p12
*.pfx

# Personal information
personal/
private/
