# secrets.yaml — Example plaintext structure
# Copy this to secrets/secrets.yaml (gitignored) and fill in real values.
# Then run: make secrets-encrypt
#
# The decrypted file uses a simple nested-key layout:
#   <namespace>.<key>
#
# Example: secret "github" "dotfiles" reads dotfiles.github_token

dotfiles:
  github_token: "REPLACE_WITH_REAL_GITHUB_TOKEN"
  gitlab_token: "REPLACE_WITH_REAL_GITLAB_TOKEN"
  aws_access_key_id: "REPLACE_WITH_REAL_AWS_KEY_ID"
  aws_secret_access_key: "REPLACE_WITH_REAL_AWS_SECRET"

personal:
  email_smtp_password: "REPLACE_WITH_REAL_EMAIL_PASSWORD"
  npm_auth_token: "REPLACE_WITH_REAL_NPM_TOKEN"
