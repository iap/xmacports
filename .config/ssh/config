# SSH configuration for development environment
# GPG-based authentication with security optimizations

# Include local server configurations (not in public dotfiles)
Include ~/.ssh/config.local

# Global defaults
Host *
    # Use GPG agent for SSH authentication
    IdentityAgent ~/.gnupg/S.gpg-agent.ssh
    
    # Security settings with backward compatibility
    Protocol 2
    Ciphers aes256-ctr,aes192-ctr,aes128-ctr,chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
    MACs hmac-sha2-256,hmac-sha2-512,hmac-sha2-256-etm@openssh.com,hmac-sha2-512-etm@openssh.com
    KexAlgorithms diffie-hellman-group16-sha512,diffie-hellman-group14-sha256,curve25519-sha256@libssh.org,diffie-hellman-group18-sha512
    HostKeyAlgorithms ssh-ed25519,ssh-rsa,ssh-ed25519-cert-v01@openssh.com,ssh-rsa-cert-v01@openssh.com
    
    # Connection settings
    ServerAliveInterval 60
    ServerAliveCountMax 3
    TCPKeepAlive yes
    Compression yes
    
    # Authentication settings
    PubkeyAuthentication yes
    PasswordAuthentication no
    KbdInteractiveAuthentication no
    
    # Host key verification
    StrictHostKeyChecking ask
    VerifyHostKeyDNS yes
    
    # Connection multiplexing for performance
    ControlMaster auto
    ControlPath ~/.cache/ssh/master-%r@%h:%p
    ControlPersist 10m
    
    # Forward GPG agent to remote hosts
    ForwardAgent yes
    
    # Disable X11 forwarding by default
    ForwardX11 no
    ForwardX11Trusted no

