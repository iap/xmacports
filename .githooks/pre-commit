#!/bin/sh
# Pre-commit hook: format/lint checks and secret detection

set -e

reject() {
  echo "ERROR: $1" >&2
  exit 1
}

# Only scan staged files (added/modified)
staged_files=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged_files" ] && exit 0

# Run format/lint (best-effort)
if command -v shfmt >/dev/null 2>&1; then
  if ! make fmt-check >/dev/null 2>&1; then
    reject "shfmt check failed. Run: make fmt-check"
  fi
fi
if command -v shellcheck >/dev/null 2>&1; then
  if ! make shellcheck >/dev/null 2>&1; then
    reject "shellcheck failed. Run: make shellcheck"
  fi
fi

# Block common private key files by name
while IFS= read -r f; do
  case "$f" in
    *.key|*.pem|*.p12|*.pfx|*.kdb|*.keystore|*.jks)
      reject "Possible private key/keystore detected: $f";;
    id_rsa|id_dsa|id_ecdsa|id_ed25519|id_ed25519_sk|id_rsa_*|id_ecdsa_*|id_dsa_*)
      reject "SSH private key detected: $f";;
    *.env.mk)
      : ;; # .env.mk is a Makefile include, not a secrets file
    secrets/secrets.enc.yaml)
      : # SOPS-encrypted file — verify it is actually encrypted below
      ;;
    *.enc.yaml|*.enc.json|*.enc)
      : ;; # Other encrypted files — assume valid if named correctly
    *.env|.env|.env.*|*secret|secrets.yaml|*secret*.yaml|*secret*.yml|*secret*.json)
      reject "Plaintext secrets file detected: $f";;
  esac
done <<EOF
$staged_files
EOF

# Verify staged SOPS encrypted files are actually encrypted
if command -v sops >/dev/null 2>&1; then
  while IFS= read -r f; do
    case "$f" in
      secrets/*.enc.yaml|*.enc.yaml)
        if ! sops -d "$f" > /dev/null 2>&1; then
          reject "SOPS encrypted file appears to be plaintext: $f (decryption failed)"
        fi
        ;;
    esac
  done <<EOF
$(git diff --cached --name-only --diff-filter=ACM)
EOF
fi

# Block PEM/OPENSSH private key content
if git diff --cached --unified=0 | grep -E "BEGIN (OPENSSH|RSA|DSA|EC|PRIVATE) KEY" >/dev/null; then
  reject "Private key content detected in staged diff"
fi

# Block common API token patterns (best-effort)
if git diff --cached --unified=0 | grep -E "(AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|AIzaSy[0-9A-Za-z_-]{35}|ghp_[0-9A-Za-z]{36}|github_pat_[0-9A-Za-z_]{80,}|xox[baprs]-[0-9A-Za-z-]{10,}|sk-[0-9A-Za-z]{20,})" >/dev/null; then
  reject "Possible API token detected in staged diff"
fi

exit 0
