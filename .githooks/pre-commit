#!/bin/bash
# TTY-aware GPG signature enforcement

# Skip verification when no TTY is attached (CI, batch, etc.)
if ! { [ -t 0 ] || [ -t 1 ] || [ -t 2 ]; }; then
    exit 0
fi

# Require a valid GPG signature when a TTY is present
if ! git log -1 --show-signature | grep -q "Good signature"; then
    echo "ERROR: Commit is not GPG-signed. Use iap@disroot.org key." >&2
    exit 1
fi
