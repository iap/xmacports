# Git Local Configuration Example
# Copy to ~/.gitconfig.local and customize
# Load priority: local config overrides base config

# Note: This file is included FIRST in .gitconfig, so any settings here
# take precedence over the base configuration. Typically used for:
# - Personal overrides (different email/name per repo)
# - Machine-specific settings (different GPG key on another device)
# - Additional aliases or excludes

# Example: Override signing for specific work repos
# [commit]
#     gpgsign = false

# Example: Additional excludes
# [core]
#     excludesfile = ~/.gitignore_work

# Example: Extra aliases
# [alias]
#     wip = commit -m "wip"