# ZSH Local Configuration Example
# Copy to ~/.zshrc.local and customize

# Personal aliases
alias myserver='ssh <username>@<hostname>'
alias myproject='cd ~/projects/<project-name>'

# Personal environment variables
export PERSONAL_VAR="<value>"

# Custom functions
connect_server() {
    ssh <username>@<server-ip> "$@"
}

