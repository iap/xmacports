# Simple Git Config for Terminal Usage

[user]
    # Personal settings in ~/.gitconfig.local

[core]
    editor = nano
    excludesfile = ~/.gitignore_global
    pager = cat

[color]
    ui = auto

[color "status"]
    added     = green bold
    changed   = yellow bold
    untracked = red bold

[color "diff"]
    old        = red bold
    new        = green bold
    frag       = cyan bold
    whitespace = red reverse

[color "branch"]
    current = cyan bold
    remote  = yellow

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    default = simple

[alias]
    # Simple commands for terminal usage
    s = status --porcelain
    l = log --oneline -10
    b = branch
    a = add
    c = commit -m
    d = diff
    
    # Quick info
    info = log --oneline -1
    files = diff --name-only
    changes = status --porcelain
    
    # Safe operations
    unstage = reset HEAD
    undo = reset --soft HEAD~1

# Include personal settings
[include]
    path = ~/.gitconfig.local
