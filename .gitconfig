# Include personal settings (load first for override priority)

[include]
    path = ~/.gitconfig.local

# Sample configuration - override in ~/.gitconfig.local
#[commit]
#    gpgsign = true

[core]
    editor = nano
    excludesfile = ~/.gitignore_global
    pager = cat

[color]
    ui = auto

[color "status"]
    added     = green bold
    changed   = yellow bold
    untracked = red bold

[color "diff"]
    old        = red bold
    new        = green bold
    frag       = cyan bold
    whitespace = red reverse

[color "branch"]
    current = cyan bold
    remote  = yellow

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    default = simple

[alias]
    s = status --porcelain
    l = log --oneline -10
    b = branch
    a = add
    c = commit -m
    d = diff

    info = log --oneline -1
    files = diff --name-only
    changes = status --porcelain

    unstage = reset HEAD
    undo = reset --soft HEAD~1
[gpg]
	program = gpg
[credential "https://github.com"]
	helper = !/nix/store/fz2h6h3cgw645ighi31zdjwbkdzmaav7-gh-2.96.0/bin/.gh-wrapped auth git-credential
[credential "https://gist.github.com"]
	helper = !/nix/store/fz2h6h3cgw645ighi31zdjwbkdzmaav7-gh-2.96.0/bin/.gh-wrapped auth git-credential
[commit]
	gpgsign = true
[user]
	signingkey = 9166D30F6FE70F56
