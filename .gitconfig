# Include personal settings (load first for override priority)

[include]
    path = ~/.gitconfig.local

# Sample configuration - override in ~/.gitconfig.local
#[commit]
#    gpgsign = true

[core]
    editor = nano
    excludesfile = ~/.gitignore_global
    pager = cat

[color]
    ui = auto

[color "status"]
    added     = green bold
    changed   = yellow bold
    untracked = red bold

[color "diff"]
    old        = red bold
    new        = green bold
    frag       = cyan bold
    whitespace = red reverse

[color "branch"]
    current = cyan bold
    remote  = yellow

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    default = simple

[alias]
    s = status --porcelain
    l = log --oneline -10
    b = branch
    a = add
    c = commit -m
    d = diff

    info = log --oneline -1
    files = diff --name-only
    changes = status --porcelain

    unstage = reset HEAD
    undo = reset --soft HEAD~1

    # Signed merge: merge a feature branch into main with --no-ff AND a GPG
    # signature, then push. Use this instead of GitLab's merge button so the
    # resulting merge commit is authored by and signed with your personal key
    # (GitLab's UI would stamp its noreply identity + GitLab's key).
    # Usage: git smerge <feature-branch>   (defaults target = main)
    smerge = "!f() { \
        target=\"${2:-main}\"; \
        src=\"${1:?usage: git smerge <feature-branch> [target=main]}\"; \
        git fetch -q origin \"$target\"; \
        git checkout \"$target\" && git merge --no-ff -S -m \"Merge branch '$src' into '$target'\" \"$src\" \
          && git log -1 --format='%h signed=%G? author=%ae' \
          && echo 'Pushing signed merge to origin...' \
          && git push origin \"$target\"; \
      }; f"

[gpg]
	program = /opt/local/bin/gpg
